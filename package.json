{
  "name": "gemini-cli-server",
  "version": "1.0.0",
  "description": "API Server for Gemini CLI to support Web/Android clients via WebSocket.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev:server": "tsx watch src/index.ts",
    "dev:cli": "tsx src/cli.ts",
    "dev:web": "npm run dev --prefix web",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@google/gemini-cli-core": "file:../gemini-cli-client/packages/core",
    "@google/gemini-cli-sdk": "file:../gemini-cli-client/packages/sdk",
    "express": "^4.19.2",
    "prompts": "^2.4.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9",
    "@types/ws": "^8.5.10",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.5.0"
  }
}
